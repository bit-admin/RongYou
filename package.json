{
  "name": "rongyou",
  "version": "1.0.0",
  "description": "Electron app for RongYou (融优学堂) course automation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.rongyou.app",
    "productName": "RongYou",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-webview.js",
      "src/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "extraResources": [
      "eng.traineddata"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": ["x64"]
        },
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Education",
      "maintainer": "RongYou <rongyou@users.noreply.github.com>"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8"
  }
}
